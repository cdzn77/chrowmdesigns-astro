---
const navLinks = [
  { label: 'Index',      href: '/' },
  { label: 'About',      href: '/about' },
  { label: 'Cases',      href: '/cases' },
  { label: 'Get In Touch', href: '/contact' },
];
---

<footer class="site-footer" role="contentinfo">
  <!-- Top section - "Let's start something bold" -->
  <div class="footer-top-section">
    <h2 class="footer-top-heading">Let's start<br />something bold</h2>
    <p class="footer-top-tagline">CHROWM<sup>®</sup> — An independent design studio,<br />based in Central Florida.</p>
  </div>

  <div class="footer-inner">

    <!-- Left column: logo + tagline -->
    <div class="footer-brand">
      <a href="/" aria-label="ChrowmDesigns — home" class="footer-logo-link">
        <svg width="40" height="40" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="1.5" fill="none"/>
          <path d="M14 4v20M4 14h20" stroke="currentColor" stroke-width="1" opacity="0.3"/>
        </svg>
      </a>
      <p class="footer-tagline">
        CHROWM<sup>®</sup> — An independent design studio,<br />
        based in Central Florida.
      </p>
    </div>

    <!-- Right column: nav + contact -->
    <div class="footer-right">

      <!-- Navigation -->
      <nav aria-label="Footer navigation">
        <ul class="footer-nav" role="list">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="footer-nav-link">{label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact -->
      <div class="footer-contact">
        <a
          href="mailto:chile@chrowmdesigns.com"
          class="footer-contact-link"
          aria-label="Send email to chile@chrowmdesigns.com"
        >
          chile@chrowmdesigns.com
        </a>
        <a
          href="https://www.linkedin.com/in/angelomanzano"
          class="footer-contact-link"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Angelo Manzano on LinkedIn (opens in new tab)"
        >
          LinkedIn
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <p class="footer-copyright">
      &copy; 2026 CHROWM | CHR&Oslash;WM DESIGNS &mdash; All Rights Reserved
    </p>
    <p class="footer-location">Central Florida</p>
  </div>
</footer>

<style is:global>
footer {
  background: #000000;
  color: #ffffff;
  margin: 0;
  padding: 0;
}

.site-footer {
  padding-bottom: 60px;
  padding-left: clamp(16px, 5vw, 60px);
  padding-right: clamp(16px, 5vw, 60px);
  max-width: 1400px;
  margin: 0 auto;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

/* Top section - "Let's start something bold" */
.footer-top-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 10vw, 80px);
  align-items: center;
  padding-top: clamp(60px, 10vw, 80px);
  padding-bottom: clamp(60px, 10vw, 80px);
  padding-left: clamp(16px, 5vw, 64px);
  padding-right: clamp(16px, 5vw, 64px);
  margin: 0 auto;
  max-width: 1400px;
}

.footer-top-heading {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(48px, 12vw, 90px);
  font-weight: 700;
  color: #ffffff;
  margin: 0;
  line-height: 1.0;
  text-transform: none;
}

.footer-top-tagline {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(16px, 4vw, 22px);
  font-weight: 400;
  color: #888888;
  margin: 0;
  text-transform: none;
  letter-spacing: 0px;
  line-height: 1.4;
  align-self: flex-end;
}

.footer-top-tagline sup {
  font-size: 0.6em;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  padding-bottom: 60px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  align-items: start;
  margin: 0;
}

/* Brand column */
.footer-brand {
  margin: 0;
  padding: 0;
}

.footer-logo-link {
  display: inline-flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20px;
  color: #60D3B8;
  text-decoration: none;
}

.footer-logo-link svg {
  height: 40px;
  width: 40px;
  display: block;
}

.footer-tagline {
  font-family: 'Manrope', sans-serif;
  font-weight: 500;
  font-size: clamp(16px, 2vw, 24px);
  letter-spacing: -0.01em;
  line-height: 1.4;
  color: #ffffff;
  max-width: 20ch;
  margin: 0;
  padding: 0;
}

.footer-tagline sup {
  font-size: 0.6em;
}

/* Right column */
.footer-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 40px;
}

/* Nav */
.footer-nav {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-auto-flow: row;
  gap: 0;
  font-family: var(--font-sans);
  font-size: 13px;
  color: rgba(242, 239, 232, 0.65);
}

.footer-nav li {
  margin: 0;
  padding: 0;
}

.footer-nav-link {
  font-size: 13px;
  font-weight: 400;
  color: rgba(242, 239, 232, 0.65);
  text-decoration: none;
  transition: color 200ms var(--transition-base);
  display: block;
  padding: 0;
}

.footer-nav-link:hover {
  color: var(--color-accent);
}

/* Contact */
.footer-contact {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0;
  font-family: var(--font-sans);
  font-size: 13px;
  color: rgba(242, 239, 232, 0.65);
  text-align: right;
}

.footer-contact-link {
  font-size: 13px;
  color: rgba(242, 239, 232, 0.65);
  text-decoration: none;
  transition: color 200ms var(--transition-base);
  padding: 0;
}

.footer-contact-link:hover {
  color: var(--color-accent);
}

/* Bottom bar */
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
  gap: 24px;
  flex-wrap: wrap;
  max-width: 1400px;
  margin: 0 auto;
  padding-left: clamp(1.5rem, 5vw, 5rem);
  padding-right: clamp(1.5rem, 5vw, 5rem);
}

.footer-copyright,
.footer-location {
  font-family: var(--font-sans);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(242, 239, 232, 0.6);
  margin: 0;
  padding: 0;
}

/* Mobile */
@media (max-width: 768px) {
  .footer-top-section {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .footer-top-tagline {
    align-self: auto;
  }

  .footer-inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .footer-right {
    align-items: flex-start;
  }

  .footer-bottom {
    flex-direction: column;
    align-items: flex-start;
  }
}
</style>
