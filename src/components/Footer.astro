---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" role="contentinfo">
  <!-- Dark top section -->
  <div class="footer-top-section">
    <a href="/contact" class="footer-top-heading">Let's start<br />something bold</a>
    <p class="footer-top-tagline">CHROWM<sup>®</sup> — An independent design studio,<br />based in Central Florida.</p>
  </div>

  <!-- White middle section -->
  <div class="footer-content">
    <!-- Navigation -->
    <nav class="footer-nav-grid" aria-label="Footer navigation">
      <a href="/" class="footer-nav-link">INDEX</a>
      <a href="/about" class="footer-nav-link">INFO</a>
      <a href="/cases" class="footer-nav-link">CASES</a>
      <a href="/contact" class="footer-nav-link">CONTACT</a>
    </nav>

    <!-- Contact info and copyright -->
    <div class="footer-info-grid">
      <div class="footer-info-left">
        <p class="footer-info-text">CHILE@CHROWMDESIGNS.COM</p>
        <p class="footer-info-text">CENTRAL FLORIDA STUDIO</p>
      </div>
      <div class="footer-info-right">
        <p class="footer-info-text">©{currentYear}</p>
        <p class="footer-info-text">COPYRIGHT CHROWMDESIGNS. ALL RIGHTS RESERVED</p>
      </div>
    </div>

    <!-- Large logo -->
    <div class="footer-logo">
      <img
        src="https://cdzn2026stg.wpenginepowered.com/wp-content/uploads/2026/05/logo.svg"
        alt="Chrowm Logo"
        class="footer-logo-img"
      />
    </div>

    <!-- Social links -->
    <div class="footer-social">
      <a href="https://www.linkedin.com/in/angelomanzano" target="_blank" rel="noopener noreferrer" class="footer-social-link">LINKEDIN</a>
      <a href="https://www.behance.net/angelomanzano" target="_blank" rel="noopener noreferrer" class="footer-social-link">BEHANCE</a>
    </div>
  </div>
</footer>

<style is:global>
footer {
  margin: 0;
  padding: 0;
}

.site-footer {
  width: 100%;
  display: flex;
  flex-direction: column;
}

/* Dark top section */
.footer-top-section {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 10vw, 80px);
  align-items: center;
  padding: clamp(60px, 10vw, 80px) clamp(16px, 5vw, 64px);
  background: #000000;
}

.footer-top-heading {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(48px, 12vw, 90px);
  font-weight: 700;
  color: #ffffff;
  margin: 0;
  line-height: 1.0;
  text-transform: none;
  text-decoration: none;
  display: inline-block;
  cursor: pointer;
  transition: all 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  background: linear-gradient(135deg, #ffffff 0%, #60D3B8 100%);
  background-size: 200% 200%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 30px rgba(96, 211, 184, 0.3);
}

.footer-top-heading:hover {
  transform: scale(1.08) skewX(-2deg);
  letter-spacing: 2px;
  text-shadow: 0 0 40px rgba(224, 43, 16, 0.6), 0 0 60px rgba(96, 211, 184, 0.4);
  background-size: 300% 300%;
  animation: color-shift 600ms ease-in-out;
}

@keyframes color-shift {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

.footer-top-tagline {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(16px, 4vw, 22px);
  font-weight: 400;
  color: #888888;
  margin: 0;
  line-height: 1.4;
  text-transform: none;
}

.footer-top-tagline sup {
  font-size: 0.6em;
}

/* White section */
.footer-content {
  background: #ffffff;
  padding: clamp(60px, 10vw, 80px) clamp(16px, 5vw, 64px);
  color: #1a1a1a;
}

/* Navigation grid */
.footer-nav-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(clamp(80px, 20vw, 120px), 1fr));
  gap: clamp(24px, 5vw, 40px);
  margin-bottom: clamp(60px, 10vw, 90px);
  padding-bottom: clamp(60px, 10vw, 90px);
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.footer-nav-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  font-weight: 400;
  color: #1a1a1a;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  text-decoration: none;
  text-align: center;
  transition: color 200ms ease;
}

.footer-nav-link:hover {
  color: #e02b10;
}

/* Contact info grid */
.footer-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(40px, 10vw, 80px);
  align-items: flex-start;
  margin-bottom: clamp(60px, 10vw, 80px);
}

.footer-info-left,
.footer-info-right {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-info-right {
  text-align: right;
}

.footer-info-text {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  font-weight: 400;
  color: #1a1a1a;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  margin: 0;
}

/* Logo */
.footer-logo {
  display: flex;
  justify-content: center;
  margin-bottom: clamp(60px, 10vw, 80px);
  overflow: hidden;
}

.footer-logo-img {
  height: clamp(180px, 30vw, 280px);
  width: 100%;
  object-fit: contain;
  max-height: clamp(180px, 30vw, 280px);
}

/* Social links */
.footer-social {
  display: flex;
  gap: clamp(24px, 5vw, 40px);
  flex-wrap: wrap;
}

.footer-social-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  font-weight: 400;
  color: #1a1a1a;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  text-decoration: none;
  transition: color 200ms ease;
}

.footer-social-link:hover {
  color: #e02b10;
}

/* Mobile */
@media (max-width: 768px) {
  .footer-top-section {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .footer-info-grid {
    grid-template-columns: 1fr;
  }

  .footer-info-right {
    text-align: left;
  }
}
</style>
