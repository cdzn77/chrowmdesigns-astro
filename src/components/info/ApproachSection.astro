---

<section style="padding-top: 160px; padding-bottom: 160px; padding-left: clamp(16px, 5vw, 60px); padding-right: clamp(16px, 5vw, 60px); background-color: #ffffff;">
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: clamp(60px, 10vw, 100px); max-width: 100%; margin: 0; align-items: start; padding-left: 40px; padding-right: clamp(16px, 5vw, 60px);">
    {/* LEFT COLUMN */}
    <div>
      <h2 style="font-size: 12px; font-weight: 400; color: #666; margin: 0 0 60px 0; font-family: JetBrains Mono, monospace; letter-spacing: 0.5px; text-transform: uppercase;">
        /APPROACH
      </h2>

      <p style="font-size: 24px; font-weight: 400; color: #000; margin: 0 0 120px 0; font-family: Manrope, sans-serif; line-height: 1.3; max-width: 500px;">
        WE DESIGN FOR THE PROBLEM, NOT THE PORTFOLIO.
      </p>

      {/* ACCORDION */}
      <div id="accordion-container" style="display: flex; flex-direction: column; gap: 0; max-width: 547px;">
        <!-- Accordion items will be rendered here -->
      </div>
    </div>

    {/* RIGHT COLUMN - IMAGE */}
    <div style="display: flex; align-items: center; justify-content: center;">
      <img src="https://cdzn2026stg.wpenginepowered.com/wp-content/uploads/2026/05/bio_approach.webp" alt="Approach" style="width: 600px; height: 600px; object-fit: cover; background-color: #000;" />
    </div>
  </div>
</section>

<script>
  function initAccordion() {
    const container = document.getElementById('accordion-container');
    if (!container) return;

    const phases = [
      {
        title: 'INSIGHT DISCOVERY',
        items: [
          'USER RESEARCH & INTERVIEWS',
          'USABILITY TESTING',
          'STAKEHOLDER ALIGNMENT',
          'COMPETITIVE ANALYSIS',
          'INSIGHT SYNTHESIS',
          'JOURNEY MAPPING'
        ]
      },
      {
        title: 'CONCEPT DEVELOPMENT',
        items: [
          'INFORMATION ARCHITECTURE',
          'USER FLOW MAPPING',
          'WIREFRAMING & PROTOTYPING',
          'DESIGN SYSTEM PLANNING',
          'INTERACTION STRATEGY',
          'CONCEPT VALIDATION'
        ]
      },
      {
        title: 'DESIGN EXECUTION',
        items: [
          'HIGH-FIDELITY DESIGN',
          'RESPONSIVE IMPLEMENTATION',
          'DESIGN SYSTEM DOCUMENTATION',
          'DEVELOPER HANDOFF',
          'QUALITY ASSURANCE',
          'POST-LAUNCH OPTIMIZATION'
        ]
      }
    ];

    let expandedIndex = 0;

    function formatItems(items) {
      return items.map((item, j) => {
        const sentenceCase = item.charAt(0).toUpperCase() + item.slice(1).toLowerCase();
        return j < items.length - 1 ? sentenceCase + ', ' : sentenceCase;
      }).join('');
    }

    function renderAccordion() {
      container.innerHTML = phases.map((phase, i) => `
        <div>
          <button class="accordion-button" data-index="${i}" style="
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 0;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
          ">
            <h3 style="
              font-size: 12px;
              font-weight: 400;
              color: #000;
              margin: 0;
              font-family: JetBrains Mono, monospace;
              letter-spacing: 0.5px;
              text-transform: uppercase;
            ">
              ${phase.title}
            </h3>
            <span class="accordion-icon" style="
              font-size: 32px;
              color: #000;
              font-weight: 100;
              flex-shrink: 0;
              line-height: 1;
              font-family: system-ui;
            ">
              ${i === expandedIndex ? '−' : '+'}
            </span>
          </button>

          <div class="accordion-content" data-index="${i}" style="
            overflow: hidden;
            max-height: ${i === expandedIndex ? '500px' : '0'};
            margin-top: ${i === expandedIndex ? '12px' : '0'};
            margin-bottom: ${i === expandedIndex ? '16px' : '0'};
            opacity: ${i === expandedIndex ? '1' : '0'};
            transition: max-height 0.3s ease, opacity 0.3s ease, margin 0.3s ease;
          ">
            <p style="
              margin: 0;
              font-size: 13px;
              font-weight: 400;
              color: #888;
              font-family: Manrope, sans-serif;
              line-height: 1.8;
            ">
              ${formatItems(phase.items)}
            </p>
          </div>

          ${i < phases.length - 1 ? `<div style="height: 1px; background-color: #ddd; margin-top: 16px; margin-bottom: 16px;"></div>` : ''}
        </div>
      `).join('');

      // Add event listeners to all buttons
      document.querySelectorAll('.accordion-button').forEach(button => {
        button.addEventListener('click', function() {
          const index = parseInt(this.dataset.index);
          expandedIndex = expandedIndex === index ? -1 : index;
          renderAccordion();
        });
      });
    }

    renderAccordion();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccordion);
  } else {
    initAccordion();
  }
</script>
