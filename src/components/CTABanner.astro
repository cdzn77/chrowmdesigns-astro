---
export interface Props {
  text?: string;
  href?: string;
}

const {
  text = "Let's start something bold",
  href = '/contact',
} = Astro.props;
---

<section class="cta-banner" aria-label="Call to action">
  <a href={href} class="cta-banner__link">
    <span class="cta-banner__text">{text}</span>
    <span class="cta-banner__arrow" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="28" cy="28" r="27.5" stroke="currentColor" stroke-opacity="0.3"/>
        <path d="M20 28H36M36 28L28 20M36 28L28 36" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</section>

<style>
  .cta-banner {
    background-color: #1B1B1B;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
    margin: 0;
  }

  .cta-banner__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding: clamp(60px, 12vw, 100px) clamp(16px, 5vw, 60px);
    text-decoration: none;
    transition: all 0.3s ease;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .cta-banner__link:hover {
    background-color: transparent;
  }

  .cta-banner__link:hover .cta-banner__text {
    color: #60D3B8;
  }

  .cta-banner__link:hover .cta-banner__arrow {
    transform: translate(8px, -8px);
    color: #60D3B8;
  }

  .cta-banner__text {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(32px, 8vw, 64px);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: #ffffff;
    transition: color 0.3s ease;
    margin: 0;
  }

  .cta-banner__arrow {
    flex-shrink: 0;
    color: var(--color-white);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s ease;
  }

  .cta-banner__arrow svg {
    width: clamp(36px, 4vw, 56px);
    height: clamp(36px, 4vw, 56px);
  }

  @media (max-width: 480px) {
    .cta-banner__arrow {
      display: none;
    }
  }
</style>
