---
export interface Props {
  text?: string;
  href?: string;
}

const {
  text = "Let's start something bold",
  href = '/contact',
} = Astro.props;
---

<section class="cta-banner" aria-label="Call to action">
  <a href={href} class="cta-banner__link">
    <span class="cta-banner__text">{text}</span>
    <span class="cta-banner__arrow" aria-hidden="true">
      <svg width="56" height="56" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="28" cy="28" r="27.5" stroke="currentColor" stroke-opacity="0.3"/>
        <path d="M20 28H36M36 28L28 20M36 28L28 36" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</section>

<style>
  .cta-banner {
    background-color: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .cta-banner__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 5rem);
    text-decoration: none;
    transition: background-color 0.35s ease;
  }

  .cta-banner__link:hover {
    background-color: rgba(96, 211, 184, 0.05);
  }

  .cta-banner__link:hover .cta-banner__text {
    color: var(--color-accent);
  }

  .cta-banner__link:hover .cta-banner__arrow {
    transform: translate(6px, -6px);
    color: var(--color-accent);
  }

  .cta-banner__text {
    font-family: var(--font-sans);
    font-size: clamp(2.2rem, 6vw, 5.5rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-white);
    transition: color 0.3s ease;
  }

  .cta-banner__arrow {
    flex-shrink: 0;
    color: var(--color-white);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), color 0.3s ease;
  }

  .cta-banner__arrow svg {
    width: clamp(36px, 4vw, 56px);
    height: clamp(36px, 4vw, 56px);
  }

  @media (max-width: 480px) {
    .cta-banner__arrow {
      display: none;
    }
  }
</style>
