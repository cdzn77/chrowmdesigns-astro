---
import cases from '../data/cases.json';

export interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const idx  = cases.findIndex((c) => c.slug === currentSlug);
const prev = idx > 0               ? cases[idx - 1] : null;
const next = idx < cases.length - 1 ? cases[idx + 1] : null;
---

<nav class="case-prevnext" aria-label="Case study navigation">
  <div class="case-prevnext__inner">
    {prev ? (
      <a href={prev.url} class="case-prevnext__link case-prevnext__link--prev">
        <span class="case-prevnext__dir">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Previous
        </span>
        <span class="case-prevnext__title">{prev.title}</span>
        <span class="case-prevnext__cat">{prev.category}</span>
      </a>
    ) : <div />}

    <div class="case-prevnext__divider" aria-hidden="true"></div>

    {next ? (
      <a href={next.url} class="case-prevnext__link case-prevnext__link--next">
        <span class="case-prevnext__dir">
          Next
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="case-prevnext__title">{next.title}</span>
        <span class="case-prevnext__cat">{next.category}</span>
      </a>
    ) : <div />}
  </div>
</nav>

<style>
  .case-prevnext {
    background-color: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .case-prevnext__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: stretch;
  }

  .case-prevnext__divider {
    width: 1px;
    background-color: rgba(255, 255, 255, 0.08);
    align-self: stretch;
  }

  .case-prevnext__link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: clamp(2rem, 4vw, 3.5rem) clamp(1.5rem, 5vw, 5rem);
    text-decoration: none;
    transition: background-color 0.25s ease;
  }

  .case-prevnext__link:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }

  .case-prevnext__link--next {
    text-align: right;
    align-items: flex-end;
  }

  .case-prevnext__link:hover .case-prevnext__title {
    color: var(--color-accent);
  }

  .case-prevnext__dir {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .case-prevnext__link:hover .case-prevnext__dir {
    color: var(--color-accent);
  }

  .case-prevnext__title {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.5vw, 1.4rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-white);
    transition: color 0.2s ease;
  }

  .case-prevnext__cat {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  @media (max-width: 640px) {
    .case-prevnext__inner {
      grid-template-columns: 1fr;
    }

    .case-prevnext__divider {
      width: 100%;
      height: 1px;
    }

    .case-prevnext__link--next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
