---
const stats = [
  { value: '44%', label: 'Decrease in\nExit Rate', description: 'Exit Rate Decrease' },
  { value: '300%', label: 'Increase in\nRegistrations', description: 'Registration Growth' },
  { value: '60M', label: 'Impressions\nDelivered', description: 'Total Impressions' },
  { value: '147%', label: 'Engagement\nLift', description: 'Engagement Increase' },
  { value: '40%', label: 'Faster Path\nto Content', description: 'Performance Gain' }
];
---

<section class="stats-section">
  <div class="stats-container">
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-item">
          <div class="stat-label-wrap">
            <p class="stat-label">{stat.label}</p>
          </div>
          <p class="stat-value">{stat.value}</p>
          <p class="stat-description">{stat.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-section {
    width: 100%;
    background-color: #ffffff;
    padding-top: clamp(60px, 12vw, 120px);
    padding-bottom: clamp(60px, 12vw, 120px);
    padding-left: clamp(16px, 5vw, 60px);
    padding-right: clamp(16px, 5vw, 60px);
  }

  .stats-container {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 80px;
    align-items: flex-start;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .stat-label-wrap {
    padding-bottom: 16px;
    border-bottom: 1px solid #d0d0d0;
    height: 40px;
    display: flex;
    align-items: flex-end;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: #1a1a1a;
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    line-height: 20px;
    word-wrap: break-word;
    white-space: pre-wrap;
    max-width: 100%;
  }

  .stat-value {
    font-size: 72px;
    font-weight: 400;
    color: #000000;
    margin: 0 0 4px 0;
    font-family: 'Manrope', sans-serif;
    line-height: 1;
  }

  .stat-description {
    font-size: 12px;
    font-weight: 400;
    color: #666666;
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.6;
    max-width: 180px;
  }

  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 640px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .stat-value {
      font-size: 48px;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
