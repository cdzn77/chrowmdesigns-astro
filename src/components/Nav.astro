---
const navLinks = [
  { label: 'Index',   href: '/' },
  { label: 'Info',    href: '/info' },
  { label: 'Cases',   href: '/cases' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const logoSrc = '/logo.svg?v=1';

// Determine variant based on current page
const isLightPage = currentPath !== '/' && !currentPath.startsWith('/cases');
const variant = isLightPage ? 'light' : 'dark';
const bgColor = variant === 'light' ? '#ffffff' : '#0f0f0f';
const textColor = variant === 'light' ? '#1a1a1a' : '#ffffff';
const borderColor = variant === 'light' ? '#f0f0f0' : '#333333';
const btnBg = variant === 'light' ? '#000' : '#ffffff';
const btnText = variant === 'light' ? '#fff' : '#000';
const logoFilter = variant === 'light' ? 'none' : 'brightness(0) invert(1)';
---

<nav
  class="site-nav"
  style={{
    backgroundColor: bgColor,
    borderBottomColor: borderColor
  }}
  role="navigation"
  aria-label="Primary navigation"
>
  <!-- Logo -->
  <a href="/" class="nav-logo-link" aria-label="ChrowmDesigns home">
    <img
      src={logoSrc}
      alt="ChrowmDesigns"
      class="nav-logo"
      style={{ filter: logoFilter }}
    />
  </a>

  <!-- Nav Links (Desktop) -->
  <div class="nav-links">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class={`nav-link${currentPath === href ? ' is-active' : ''}`}
        style={{ color: textColor }}
        aria-current={currentPath === href ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </div>

  <!-- CTA Button (Desktop) -->
  <a
    href="/contact"
    class="nav-cta"
    style={{
      backgroundColor: btnBg,
      color: btnText
    }}
  >
    Let's Talk
  </a>

  <!-- Mobile Menu Toggle -->
  <button
    class="nav-mobile-toggle"
    id="mobile-menu-toggle"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    style={{ color: textColor }}
  >
    <span class="nav-mobile-toggle__line"></span>
    <span class="nav-mobile-toggle__line"></span>
    <span class="nav-mobile-toggle__line"></span>
  </button>

  <!-- Mobile Menu -->
  <div
    class="nav-mobile-menu"
    id="mobile-menu"
    style={{
      backgroundColor: bgColor,
      borderTopColor: borderColor
    }}
  >
    <div class="nav-mobile-menu__inner">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={`nav-mobile-link${currentPath === href ? ' is-active' : ''}`}
          style={{ color: textColor }}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="nav-mobile-cta"
        style={{
          backgroundColor: btnBg,
          color: btnText
        }}
      >
        Let's Talk
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', !isExpanded);
      menu.classList.toggle('is-open');
    });

    // Close menu when a link is clicked
    const links = menu.querySelectorAll('a');
    links.forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.classList.remove('is-open');
      });
    });
  }
</script>

<style define:vars={{ bgColor, textColor, borderColor, btnBg, btnText }}>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 102;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px clamp(16px, 5vw, 60px);
    border-bottom: 1px solid var(--borderColor);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .nav-logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .nav-logo {
    height: 20px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: clamp(20px, 5vw, 40px);
    align-items: center;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 400;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease-out;
    cursor: pointer;
  }

  .nav-link:hover {
    color: #e02b10;
  }

  .nav-link.is-active {
    color: #e02b10;
  }

  .nav-cta {
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .nav-mobile-toggle__line {
    width: 24px;
    height: 2px;
    background-color: currentColor;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center;
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(2) {
    opacity: 0;
    transform: translateX(-8px);
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -8px);
  }

  @keyframes slideInMenu {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes fadeInOverlay {
    from {
      opacity: 0;
      backdrop-filter: blur(0px);
    }
    to {
      opacity: 1;
      backdrop-filter: blur(4px);
    }
  }

  @keyframes slideOutMenu {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(-100%);
      opacity: 0;
    }
  }

  @keyframes fadeOutOverlay {
    from {
      opacity: 1;
      backdrop-filter: blur(4px);
    }
    to {
      opacity: 0;
      backdrop-filter: blur(0px);
    }
  }

  .nav-mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 101;
    background-color: var(--bgColor);
    flex-direction: column;
    animation: slideOutMenu 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    backdrop-filter: blur(0px);
  }

  .nav-mobile-menu::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0);
    z-index: -1;
    animation: fadeOutOverlay 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu.is-open {
    display: flex;
    animation: slideInMenu 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu.is-open::before {
    animation: fadeInOverlay 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu__inner {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 80px 20px 20px 20px;
    overflow-y: auto;
    height: 100vh;
  }

  .nav-mobile-link {
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease-out;
    cursor: pointer;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .nav-mobile-link:hover {
    color: #e02b10;
  }

  .nav-mobile-link.is-active {
    color: #e02b10;
  }

  .nav-mobile-cta {
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 12px 16px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
    display: inline-block;
    text-align: center;
    margin-top: 12px;
  }

  .nav-mobile-cta:hover {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .nav-cta {
      display: none;
    }

    .nav-mobile-toggle {
      display: flex !important;
    }
  }
</style>
