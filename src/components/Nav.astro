---
const navLinks = [
  { label: 'Index',   href: '/' },
  { label: 'Info',    href: '/info' },
  { label: 'Cases',   href: '/cases' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const logoSrc = '/logo.svg?v=1';

// Determine variant based on current page
const isLightPage = currentPath !== '/' && !currentPath.startsWith('/cases');
const variant = isLightPage ? 'light' : 'dark';
const bgColor = variant === 'light' ? '#ffffff' : '#0f0f0f';
const textColor = variant === 'light' ? '#1a1a1a' : '#ffffff';
const borderColor = variant === 'light' ? '#f0f0f0' : '#333333';
const btnBg = variant === 'light' ? '#000' : '#ffffff';
const btnText = variant === 'light' ? '#fff' : '#000';
const logoFilter = variant === 'light' ? 'none' : 'brightness(0) invert(1)';
---

<nav
  class="site-nav"
  style={{
    backgroundColor: bgColor,
    borderBottomColor: borderColor
  }}
  role="navigation"
  aria-label="Primary navigation"
>
  <!-- Logo -->
  <a href="/" class="nav-logo-link" aria-label="ChrowmDesigns home">
    <img
      src={logoSrc}
      alt="ChrowmDesigns"
      class="nav-logo"
      style={{ filter: logoFilter }}
    />
  </a>

  <!-- Nav Links (Desktop) -->
  <div class="nav-links">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class={`nav-link${currentPath === href ? ' is-active' : ''}`}
        style={{ color: textColor }}
        aria-current={currentPath === href ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </div>

  <!-- CTA Button (Desktop) -->
  <a
    href="/contact"
    class="nav-cta"
    style={{
      backgroundColor: btnBg,
      color: btnText
    }}
  >
    Let's Talk
  </a>

  <!-- Mobile Menu Toggle -->
  <button
    class="nav-mobile-toggle"
    id="mobile-menu-toggle"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    style={{ color: textColor }}
  >
    <span class="nav-mobile-toggle__line"></span>
    <span class="nav-mobile-toggle__line"></span>
    <span class="nav-mobile-toggle__line"></span>
  </button>

  <!-- Mobile Menu -->
  <div
    class="nav-mobile-menu"
    id="mobile-menu"
    style={{
      backgroundColor: bgColor,
      borderTopColor: borderColor
    }}
  >
    <!-- Close Button -->
    <button
      class="nav-mobile-menu__close"
      id="mobile-menu-close"
      aria-label="Close navigation menu"
      style={{ color: textColor }}
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>

    <div class="nav-mobile-menu__inner">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={`nav-mobile-link${currentPath === href ? ' is-active' : ''}`}
          style={{ color: textColor }}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href="/contact"
        class="nav-mobile-cta"
        style={{
          backgroundColor: btnBg,
          color: btnText
        }}
      >
        Let's Talk
      </a>

      <!-- Footer Section -->
      <div class="nav-mobile-menu__footer">
        <!-- Social & Contact Links -->
        <div class="nav-mobile-menu__footer-links">
          <a href="mailto:chile@chrowmdesigns.com" class="nav-mobile-footer-link" style={{ color: textColor }}>
            EMAIL
          </a>
          <a href="https://www.linkedin.com/in/angelomanzano" target="_blank" rel="noopener noreferrer" class="nav-mobile-footer-link" style={{ color: textColor }}>
            LINKEDIN
          </a>
          <a href="https://chrowmdesigns.com/cv.pdf" download class="nav-mobile-footer-link" style={{ color: textColor }}>
            RESUME
          </a>
        </div>

        <!-- Logo -->
        <div class="nav-mobile-menu__footer-logo">
          <img
            src={logoSrc}
            alt="ChrowmDesigns"
            style={{ filter: logoFilter }}
          />
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const closeButton = document.getElementById('mobile-menu-close');

  function closeMenu() {
    toggle.setAttribute('aria-expanded', 'false');
    menu.classList.remove('is-open');
  }

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', !isExpanded);
      menu.classList.toggle('is-open');
    });

    // Close menu when close button is clicked
    if (closeButton) {
      closeButton.addEventListener('click', closeMenu);
    }

    // Close menu when a link is clicked
    const links = menu.querySelectorAll('a:not(.nav-mobile-menu__close)');
    links.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }
</script>

<style define:vars={{ bgColor, textColor, borderColor, btnBg, btnText }}>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 102;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px clamp(16px, 5vw, 60px);
    border-bottom: 1px solid var(--borderColor);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .nav-logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .nav-logo {
    height: 20px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: clamp(20px, 5vw, 40px);
    align-items: center;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 400;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease-out;
    cursor: pointer;
  }

  .nav-link:hover {
    color: #e02b10;
  }

  .nav-link.is-active {
    color: #e02b10;
  }

  .nav-cta {
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
    display: inline-flex;
    align-items: center;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .nav-mobile-toggle__line {
    width: 24px;
    height: 2px;
    background-color: currentColor;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transform-origin: center;
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(2) {
    opacity: 0;
    transform: translateX(-8px);
  }

  .nav-mobile-toggle[aria-expanded="true"] .nav-mobile-toggle__line:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -8px);
  }

  @keyframes slideInMenu {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(0);
    }
  }

  @keyframes fadeInOverlay {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes slideOutMenu {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-100%);
    }
  }

  @keyframes fadeOutOverlay {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  .nav-mobile-menu {
    display: flex;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 101;
    background-color: var(--bgColor);
    flex-direction: column;
    backdrop-filter: blur(4px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    animation: slideOutMenu 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.2);
    z-index: -1;
    animation: fadeOutOverlay 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    animation: slideInMenu 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu.is-open::before {
    animation: fadeInOverlay 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .nav-mobile-menu__close {
    position: fixed;
    top: clamp(12px, 3vw, 20px);
    right: clamp(12px, 3vw, 20px);
    z-index: 103;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    color: inherit;
    transition: opacity 0.2s ease-out;
  }

  .nav-mobile-menu__close:hover {
    opacity: 0.7;
  }

  .nav-mobile-menu__close svg {
    width: 32px;
    height: 32px;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nav-mobile-menu__inner {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: clamp(80px, 10vw, 120px) clamp(20px, 5vw, 60px) clamp(40px, 8vw, 80px) clamp(20px, 5vw, 60px);
    overflow-y: auto;
    height: 100vh;
  }

  .nav-mobile-link {
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease-out;
    cursor: pointer;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .nav-mobile-link:hover {
    color: #e02b10;
  }

  .nav-mobile-link.is-active {
    color: #e02b10;
  }

  .nav-mobile-cta {
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 12px 16px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease;
    display: inline-block;
    text-align: center;
    margin-top: clamp(40px, 8vw, 80px);
    width: 100%;
  }

  .nav-mobile-cta:hover {
    opacity: 0.85;
  }

  .nav-mobile-menu__footer {
    display: flex;
    flex-direction: column;
    gap: clamp(40px, 8vw, 80px);
    margin-top: auto;
    padding-top: clamp(40px, 8vw, 80px);
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .nav-mobile-menu__footer-links {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 4vw, 32px);
  }

  .nav-mobile-footer-link {
    font-size: 12px;
    font-weight: 400;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease-out;
  }

  .nav-mobile-footer-link:hover {
    color: #e02b10;
  }

  .nav-mobile-menu__footer-logo {
    display: flex;
    justify-content: center;
    padding-bottom: clamp(20px, 5vw, 40px);
  }

  .nav-mobile-menu__footer-logo img {
    height: clamp(60px, 15vw, 120px);
    width: auto;
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .nav-cta {
      display: none;
    }

    .nav-mobile-toggle {
      display: flex !important;
    }
  }
</style>
