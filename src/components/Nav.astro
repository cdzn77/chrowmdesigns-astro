---
const navLinks = [
  { label: 'Index',   href: '/' },
  { label: 'Info',    href: '/info' },
  { label: 'Cases',   href: '/cases' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
const logoSrc = '/logo.svg';

// Determine variant based on current page
const isLightPage = currentPath !== '/' && !currentPath.startsWith('/cases');
const variant = isLightPage ? 'light' : 'dark';
const bgColor = variant === 'light' ? '#ffffff' : '#0f0f0f';
const textColor = variant === 'light' ? '#1a1a1a' : '#ffffff';
const borderColor = variant === 'light' ? '#f0f0f0' : '#333333';
const btnBg = variant === 'light' ? '#000' : '#ffffff';
const btnText = variant === 'light' ? '#fff' : '#000';
const logoFilter = variant === 'light' ? 'none' : 'brightness(0) invert(1)';
---

<nav
  class="site-nav"
  style={{
    backgroundColor: bgColor,
    borderBottomColor: borderColor
  }}
  role="navigation"
  aria-label="Primary navigation"
>
  <!-- Logo -->
  <a href="/" class="nav-logo-link" aria-label="ChrowmDesigns home">
    <img
      src={logoSrc}
      alt="ChrowmDesigns"
      class="nav-logo"
      style={{ filter: logoFilter }}
    />
  </a>

  <!-- Nav Links -->
  <div class="nav-links">
    {navLinks.map(({ label, href }) => (
      <a
        href={href}
        class={`nav-link${currentPath === href ? ' is-active' : ''}`}
        style={{ color: textColor }}
        aria-current={currentPath === href ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </div>

  <!-- CTA Button -->
  <a
    href="/contact"
    class="nav-cta"
    style={{
      backgroundColor: btnBg,
      color: btnText
    }}
  >
    Let's Talk
  </a>
</nav>

<style define:vars={{ bgColor, textColor, borderColor, btnBg, btnText }}>
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap');

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px clamp(16px, 5vw, 60px);
    border-bottom: 1px solid var(--borderColor);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .nav-logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .nav-logo {
    height: 20px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: clamp(20px, 5vw, 40px);
    align-items: center;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 400;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    transition: color 0.2s ease-out;
    cursor: pointer;
  }

  .nav-link:hover {
    color: #e02b10;
  }

  .nav-link.is-active {
    color: #e02b10;
  }

  .nav-cta {
    font-size: 12px;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    border: none;
    border-radius: 0;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
