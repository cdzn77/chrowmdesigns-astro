---
// Hero renders a full-viewport video background matching React ChrowmDesigns design exactly.
// Orange background with video overlay, white text, structured layout with dark stat cards.
---

<section class="hero">
  <!-- Background Video -->
  <div class="hero__video-wrap" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
    >
      <source src="/video/hero.webm" type="video/webm" />
      <source src="/video/hero.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Main Content -->
  <div class="hero__content">
    <!-- Top Section: Info columns -->
    <div class="hero__top-section">
      <div class="hero__info-left">
        <p class="hero__label">Senior UX<br />Strategist</p>
        <p class="hero__tagline">20 years designing<br />digital products that<br />inspire users</p>
      </div>

      <div class="hero__info-right">
        <p class="hero__description">
          Design that performs. Gaming, hospitality, entertainment, and CPG brands trust ChrowmDesigns to deliver digital experiences that move the numbers.
        </p>
        <p class="hero__keywords">
          Strategy · UX · Interactive Design<br />Digital Experiences · Brand Transformation
        </p>
      </div>
    </div>

    <!-- Bottom Section: Headline + CTA + Stats -->
    <div class="hero__bottom-section">
      <!-- Left: Headline + CTA -->
      <div class="hero__cta-block">
        <h1 class="hero__heading">designed to<br />connect</h1>
        <p class="hero__sub">Crafting digital experiences that<br />connect, engage and inspire.</p>
        <button class="hero__cta">let's talk design</button>
      </div>

      <!-- Right: Stat Cards -->
      <div class="hero__stats">
        <div class="hero__stat-card">
          <p class="hero__stat-value">20+</p>
          <p class="hero__stat-label">Years<br />experience</p>
        </div>
        <div class="hero__stat-card">
          <p class="hero__stat-value">6</p>
          <p class="hero__stat-label">Featured<br />projects</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Root container - orange background with video */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background-color: #e02b10;
    overflow: hidden;
  }

  /* Background Video */
  .hero__video-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Main Content */
  .hero__content {
    position: relative;
    z-index: 20;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: clamp(16px, 4vw, 32px);
    padding-top: clamp(80px, 15vw, 120px);
  }

  /* Top Section: Info columns */
  .hero__top-section {
    display: flex;
    justify-content: space-between;
    gap: clamp(16px, 5vw, 32px);
    margin-bottom: 32px;
    flex: 1;
    align-items: flex-start;
  }

  .hero__info-left {
    max-width: clamp(200px, 40vw, 260px);
  }

  .hero__label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    line-height: 1.3;
    margin-bottom: 8px;
    color: white;
    margin: 0 0 8px 0;
    font-family: 'JetBrains Mono', monospace;
  }

  .hero__tagline {
    font-size: 12px;
    line-height: 1.5;
    opacity: 0.8;
    color: white;
    margin: 0;
    font-weight: 400;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

  .hero__info-right {
    max-width: clamp(200px, 40vw, 320px);
  }

  .hero__description {
    font-size: 12px;
    line-height: 1.6;
    margin-bottom: 12px;
    color: white;
    margin: 0;
    font-weight: 400;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

  .hero__keywords {
    font-size: 12px;
    line-height: 1.7;
    opacity: 0.7;
    color: white;
    margin: 0;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

  /* Bottom Section: Headline + CTA + Stats */
  .hero__bottom-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
  }

  .hero__cta-block {
    flex: 1;
  }

  .hero__heading {
    font-family: 'Geist', sans-serif;
    font-weight: 400;
    font-size: clamp(56px, 13vw, 175px);
    letter-spacing: -0.04em;
    line-height: 0.78;
    color: white;
    margin: 0 0 24px 0;
    width: fit-content;
    text-transform: none;
  }

  .hero__sub {
    font-size: 12px;
    line-height: 1.5;
    color: white;
    margin-bottom: 16px;
    margin: 0 0 16px 0;
    font-weight: 400;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

  .hero__cta {
    display: inline-block;
    background-color: black;
    color: white;
    border: none;
    border-radius: 0;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 12px;
    padding: clamp(12px, 3vw, 16px) clamp(24px, 8vw, 48px);
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    transition: background-color 0.2s;
    text-decoration: none;
    text-transform: uppercase;
    min-width: 44px;
    min-height: 44px;
  }

  .hero__cta:hover {
    background-color: #333333;
  }

  /* Stat Cards: Dark semi-transparent design */
  .hero__stats {
    display: flex;
    gap: 16px;
    flex-shrink: 0;
    flex-wrap: nowrap;
    overflow: auto;
  }

  .hero__stat-card {
    width: 150px;
    height: 150px;
    padding: 20px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: rgba(0, 0, 0, 0.65);
    border: 1px solid rgba(255, 255, 255, 0.15);
    text-align: left;
    transition: transform 0.3s;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    flex-shrink: 0;
  }

  .hero__stat-card:hover {
    transform: translateY(-4px);
  }

  .hero__stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #ffffff;
    line-height: 1;
    margin: 0;
    font-weight: 700;
    text-transform: uppercase;
  }

  .hero__stat-label {
    font-size: 12px;
    color: #cccccc;
    margin: 0;
    margin-top: auto;
    white-space: pre-line;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__content {
      padding: clamp(16px, 4vw, 32px);
      padding-top: clamp(80px, 15vw, 120px);
    }

    .hero__top-section {
      flex-direction: column;
      gap: clamp(16px, 5vw, 32px);
      margin-bottom: 32px;
    }

    .hero__bottom-section {
      flex-direction: column;
      gap: 32px;
    }

    .hero__stats {
      width: 100%;
      overflow-x: auto;
    }

    .hero__stat-card {
      flex-shrink: 0;
    }
  }
</style>
