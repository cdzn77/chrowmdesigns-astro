---
// Hero renders a full-viewport video background with React creative studio design.
// Orange background with video overlay, white text, modern layout.
---

<section class="hero" aria-label="Introduction">

  <!-- Video layer — autoplay, muted, loop, no controls -->
  <div class="hero__video-wrap" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster="/images/marriott_tablet_home.webp"
    >
      <source src="/video/cdzn_showreel.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>
  </div>

  <!-- Content: Two-section layout (top info, bottom headline+stats) -->
  <div class="hero__content">
    <!-- Top Section: About + Byline -->
    <div class="hero__top-section">
      <div class="hero__info-left">
        <p class="hero__label">Senior Product Designer</p>
        <p class="hero__tagline">20 years crafting digital products that connect and perform</p>
      </div>
      <div class="hero__info-right">
        <p class="hero__description">I design end-to-end digital experiences that balance user needs with bold brand expression. Strategic thinking meets creative excellence.</p>
      </div>
    </div>

    <!-- Bottom Section: Headline + CTA + Stats -->
    <div class="hero__bottom-section">
      <div class="hero__cta-block">
        <h1 class="hero__heading">Designed to<br />Connect.</h1>
        <p class="hero__sub">Strategic design for digital products and brands that inspire.</p>
        <a href="/contact" class="hero__cta">
          Let's Talk Design
          <span class="hero__cta-arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 9H15M15 9L9 3M15 9L9 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>

      <!-- Stat Cards: Glassmorphism design -->
      <div class="hero__stats">
        <div class="hero__stat-card">
          <p class="hero__stat-value">20+</p>
          <p class="hero__stat-label">Years Experience</p>
        </div>
        <div class="hero__stat-card">
          <p class="hero__stat-value">50+</p>
          <p class="hero__stat-label">Projects Delivered</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem clamp(1.5rem, 5vw, 5rem);
    overflow: hidden;
    background-color: var(--color-hero-bg);
  }

  /* Video */
  .hero__video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.15) 100%
    );
  }

  /* Content: Full-width flex layout */
  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1400px;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Top Section: Two-column info layout */
  .hero__top-section {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    align-items: flex-start;
  }

  .hero__info-left {
    flex: 0 0 auto;
    max-width: 280px;
  }

  .hero__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: white;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .hero__tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
    font-weight: 400;
  }

  .hero__info-right {
    flex: 1;
    max-width: 380px;
  }

  .hero__description {
    font-size: 0.9rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-weight: 400;
  }

  /* Bottom Section: Headline + CTA on left, stats on right */
  .hero__bottom-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
  }

  .hero__cta-block {
    flex: 1;
  }

  .hero__heading {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 11vw, 7.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.85;
    color: white;
    margin: 0 0 1.5rem 0;
    text-transform: capitalize;
  }

  .hero__sub {
    font-size: clamp(0.95rem, 1.2vw, 1.1rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 1.5rem 0;
    font-weight: 400;
    max-width: 500px;
  }

  /* CTA button - React design: pill-shaped white button */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2.2rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #1a1a1a;
    background-color: white;
    border-radius: 20px;
    border: none;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    cursor: pointer;
  }

  .hero__cta:hover {
    background-color: #f5f5f5;
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
    gap: 0.9rem;
  }

  .hero__cta-arrow {
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  .hero__cta:hover .hero__cta-arrow {
    transform: translateX(2px);
  }

  /* Stat Cards: Glassmorphism */
  .hero__stats {
    display: flex;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .hero__stat-card {
    min-width: 140px;
    min-height: 140px;
    padding: 1.5rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .hero__stat-value {
    font-family: var(--font-sans);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1;
    margin: 0;
  }

  .hero__stat-label {
    font-size: 0.7rem;
    color: #888;
    margin: 0;
    margin-top: auto;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Scroll indicator */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 100%);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50%       { opacity: 1;   transform: scaleY(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line { animation: none; }
    .hero__video { display: none; }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3rem 1.5rem;
    }

    .hero__top-section {
      flex-direction: column;
      gap: 2rem;
    }

    .hero__info-right {
      max-width: 100%;
    }

    .hero__bottom-section {
      flex-direction: column;
      gap: 2rem;
    }

    .hero__stats {
      width: 100%;
      gap: 1rem;
    }

    .hero__stat-card {
      flex: 1;
      min-height: 120px;
    }

    .hero__heading {
      font-size: clamp(2.5rem, 8vw, 4rem);
    }

    .hero__scroll {
      display: none;
    }
  }
</style>
