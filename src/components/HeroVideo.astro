---
// Hero renders a full-viewport video background matching React creative studio design exactly.
// Orange background with video overlay, white text, structured layout.
---

<div class="hero" aria-label="Introduction">

  <!-- Background Video -->
  <div class="hero__video-wrap" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      preload="none"
      poster="/images/marriott_tablet_home.webp"
    >
      <source src="/video/cdzn_showreel.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Navbar -->
  <nav class="hero__nav" aria-label="Primary navigation">
    <!-- Left: Logo + Nav Items -->
    <div class="hero__nav-left">
      <!-- Logo -->
      <svg class="hero__logo" width="30" height="22" viewBox="0 0 30 22" fill="none" aria-hidden="true">
        <path d="M2 4C2 4 8 1 15 6C22 11 28 8 28 8" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
        <path d="M2 16C2 16 8 13 15 18C22 23 28 20 28 20" stroke="white" stroke-width="3.5" stroke-linecap="round"/>
      </svg>

      <!-- Nav Items -->
      <div class="hero__nav-items">
        <a href="/" class="hero__nav-link hero__nav-link--active">HOME</a>
        <a href="/cases" class="hero__nav-link">WORK</a>
        <a href="/about" class="hero__nav-link">ABOUT</a>
      </div>
    </div>

    <!-- Right: CTA -->
    <div class="hero__nav-right">
      <a href="/contact" class="hero__nav-cta">Contact</a>
    </div>
  </nav>

  <!-- Main Content -->
  <div class="hero__content">
    <!-- Top Section: Info columns -->
    <div class="hero__top-section">
      <div class="hero__info-left">
        <p class="hero__label">Senior Product Designer</p>
        <p class="hero__tagline">20 years crafting digital products that connect and inspire</p>
      </div>

      <div class="hero__info-right">
        <p class="hero__description">
          I design end-to-end digital experiences that balance user needs with bold brand expression. Strategic design for products and brands that own their category.
        </p>
      </div>
    </div>

    <!-- Bottom Section: Headline + CTA + Stats -->
    <div class="hero__bottom-section">
      <!-- Left: Headline + CTA -->
      <div class="hero__cta-block">
        <h1 class="hero__heading">Designed to<br />Connect.</h1>
        <p class="hero__sub">Strategic design for digital products and brands that inspire.</p>
        <a href="/contact" class="hero__cta">Let's Talk Design</a>
      </div>

      <!-- Right: Stat Cards -->
      <div class="hero__stats">
        <div class="hero__stat-card">
          <p class="hero__stat-value">20+</p>
          <p class="hero__stat-label">Years</p>
        </div>
        <div class="hero__stat-card">
          <p class="hero__stat-value">50+</p>
          <p class="hero__stat-label">Projects</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Root container - React design: orange background with video */
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background-color: #e02b10;
    overflow: hidden;
  }

  /* Background Video */
  .hero__video-wrap {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Navigation Bar - React design exact styling */
  .hero__nav {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 16px;
    background-color: rgba(0, 0, 0, 0.15);
  }

  .hero__nav-left {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .hero__logo {
    height: 22px;
    width: 30px;
    display: block;
    flex-shrink: 0;
  }

  .hero__nav-items {
    display: flex;
    gap: 8px;
  }

  .hero__nav-link {
    background-color: transparent;
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.6);
    font-size: 12px;
    font-weight: 400;
    padding: 8px 20px;
    border-radius: 20px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .hero__nav-link--active {
    background-color: white;
    color: black;
    border: none;
    font-weight: 700;
  }

  .hero__nav-link:hover {
    border-color: white;
  }

  .hero__nav-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero__nav-cta {
    background-color: transparent;
    color: white;
    border: 1px solid white;
    font-size: 12px;
    padding: 8px 16px;
    border-radius: 20px;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }

  .hero__nav-cta:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* Main Content */
  .hero__content {
    position: relative;
    z-index: 20;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 16px;
    padding-top: 72px;
  }

  /* Top Section: Info columns */
  .hero__top-section {
    display: flex;
    justify-content: space-between;
    gap: 32px;
    margin-bottom: 32px;
    flex: 1;
    align-items: flex-start;
  }

  .hero__info-left {
    max-width: 260px;
  }

  .hero__label {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    line-height: 1.3;
    margin-bottom: 8px;
    color: white;
    margin: 0 0 8px 0;
  }

  .hero__tagline {
    font-size: 13px;
    line-height: 1.5;
    opacity: 0.8;
    color: white;
    margin: 0;
    font-weight: 400;
  }

  .hero__info-right {
    max-width: 320px;
  }

  .hero__description {
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 12px;
    color: white;
    margin: 0;
    font-weight: 400;
  }

  /* Bottom Section: Headline + CTA + Stats */
  .hero__bottom-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 32px;
  }

  .hero__cta-block {
    flex: 1;
  }

  .hero__heading {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(56px, 13vw, 155px);
    letter-spacing: -0.04em;
    line-height: 0.78;
    color: white;
    margin: 0 0 24px 0;
    width: fit-content;
  }

  .hero__sub {
    font-size: 14px;
    line-height: 1.5;
    color: white;
    margin-bottom: 16px;
    margin: 0 0 16px 0;
    font-weight: 400;
  }

  .hero__cta {
    display: inline-block;
    background-color: white;
    color: black;
    border: none;
    border-radius: 20px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    padding: 16px 48px;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    transition: background-color 0.2s;
    text-decoration: none;
  }

  .hero__cta:hover {
    background-color: #f3f4f6;
  }

  /* Stat Cards: React glassmorphism design */
  .hero__stats {
    display: flex;
    gap: 16px;
    flex-shrink: 0;
  }

  .hero__stat-card {
    min-width: 150px;
    min-height: 150px;
    padding: 20px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .hero__stat-value {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 6vw, 2.6rem);
    color: #111;
    line-height: 1;
    margin: 0;
    font-weight: 700;
  }

  .hero__stat-label {
    font-size: 12px;
    color: #888;
    margin: 0;
    margin-top: auto;
    font-weight: 400;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero__content {
      padding: 16px;
      padding-top: 72px;
    }

    .hero__top-section {
      flex-direction: column;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .hero__bottom-section {
      flex-direction: column;
      gap: 2rem;
    }

    .hero__stats {
      width: 100%;
    }

    .hero__stat-card {
      flex: 1;
    }

    .hero__nav-items {
      display: none;
    }
  }
</style>
