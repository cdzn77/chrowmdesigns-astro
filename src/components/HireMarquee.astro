---
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');
---

<section class="hire-section">
  <h2 class="hire-section__title">Product Designer Available for Hire</h2>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');

  .hire-section {
    width: 100%;
    background-color: #ffffff;
    padding: clamp(100px, 18vw, 160px) clamp(16px, 5vw, 60px);
    margin: 0;
  }

  .hire-section__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(48px, 12vw, 140px);
    font-weight: 700;
    color: #000000;
    margin: 0;
    line-height: 1;
    text-transform: none;
    letter-spacing: -0.02em;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
