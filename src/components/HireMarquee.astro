---
const text = 'Product Designer Available for Hire + UX Strategy & Design Systems + Remote & Worldwide + 20 Years of Experience +';
---

<div class="hire-marquee" aria-hidden="true">
  <div class="hire-marquee__track">
    {[0, 1].map(() => (
      <span class="hire-marquee__item">{text}</span>
    ))}
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');

  .hire-marquee {
    overflow: hidden;
    background-color: #ffffff;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    position: relative;
  }

  .hire-marquee__track {
    display: flex;
    width: max-content;
    animation: marquee 24s linear infinite;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .hire-marquee__item {
    font-family: 'Manrope', sans-serif;
    font-size: 170px;
    font-weight: 400;
    color: #000000;
    white-space: nowrap;
    line-height: 1;
    padding: 40px 0;
    margin-right: 0;
    text-transform: none;
    letter-spacing: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hire-marquee__track {
      animation: none;
    }
  }
</style>
