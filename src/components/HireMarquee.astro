---

<section class="hire-section">
  <div class="hire-section__content">
    <h2 class="hire-section__title">Product Designer Available for Hire</h2>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap');

  .hire-section {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    background-color: #ffffff;
    padding: clamp(60px, 15vw, 120px) clamp(16px, 5vw, 60px);
  }

  .hire-section__content {
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
  }

  .hire-section__title {
    font-family: 'Manrope', sans-serif;
    font-size: clamp(48px, 12vw, 120px);
    font-weight: 700;
    color: #000000;
    margin: 0;
    line-height: 1.1;
    text-transform: none;
    letter-spacing: -0.02em;
  }

  @media (max-width: 768px) {
    .hire-section__title {
      font-size: clamp(32px, 10vw, 80px);
    }
  }
</style>
