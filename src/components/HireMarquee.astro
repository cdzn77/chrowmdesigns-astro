---
// Items from hire marquee
const items = [
  'Product Designer Available for Hire',
  'UX Strategy & Design Systems',
  'Remote & Worldwide',
  '20 Years of Experience',
];

const sep = '+';
---

<div class="hire-marquee" aria-hidden="true">
  <div class="hire-marquee__track">
    {[0, 1].map(() => (
      <div class="hire-marquee__set" role="presentation">
        {items.map((item) => (
          <>
            <span class="hire-marquee__item">{item}</span>
            <span class="hire-marquee__sep" aria-hidden="true">{sep}</span>
          </>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .hire-marquee {
    overflow: hidden;
    background-color: #ffffff;
    padding: 2rem 0;
  }

  .hire-marquee__track {
    display: flex;
    width: max-content;
    animation: crd-marquee-scroll-reverse 25s linear infinite !important;
  }

  .hire-marquee__set {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .hire-marquee__item {
    font-family: 'Manrope', sans-serif;
    font-size: 170px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: #000000;
    white-space: nowrap;
    padding: 0 24px;
  }

  .hire-marquee__sep {
    font-size: 12px;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.2);
    flex-shrink: 0;
  }

  @keyframes crd-marquee-scroll-reverse {
    from { transform: translate3d(-50%, 0, 0); }
    to   { transform: translate3d(0, 0, 0); }
  }
</style>
