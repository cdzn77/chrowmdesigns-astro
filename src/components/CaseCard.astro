---
export interface Props {
  title: string;
  category: string;
  thumbnail: string;
  href: string;
  description?: string;
  /** Optional: stagger the card downward for masonry feel */
  offset?: boolean;
  loading?: 'lazy' | 'eager';
}

const {
  title,
  category,
  thumbnail,
  href,
  description,
  offset = false,
  loading = 'lazy',
} = Astro.props;
---

<article class:list={['case-card', { 'case-card--offset': offset }]}>
  <a href={href} class="case-card__link" aria-label={`View case study: ${title}`}>

    <!-- Thumbnail -->
    <div class="case-card__img-wrap">
      <img
        src={thumbnail}
        alt={title}
        class="case-card__img"
        loading={loading}
        decoding="async"
        width="760"
        height="520"
      />
      <!-- Hover overlay -->
      <div class="case-card__hover-overlay" aria-hidden="true">
        <span class="case-card__view-label">View Case</span>
      </div>
    </div>

    <!-- Meta -->
    <div class="case-card__meta">
      <h3 class="case-card__title">{title}</h3>
      <span class="case-card__category">{category}</span>
      {description && (
        <p class="case-card__desc">{description}</p>
      )}
    </div>

  </a>
</article>

<style>
  .case-card {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    background: #ffffff;
    height: 100%;
  }

  .case-card--offset {
    margin-top: 0;
  }

  .case-card__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    gap: 0;
    margin: 0;
    padding: 0;
    height: 100%;
  }

  .case-card__img-wrap {
    position: relative;
    overflow: hidden;
    width: 100%;
    background-color: #f5f5f5;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .case-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .case-card__link:hover .case-card__img {
    transform: scale(1.05);
  }

  .case-card__hover-overlay {
    display: none;
  }

  .case-card__view-label {
    display: none;
  }

  .case-card__meta {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    background: #ffffff;
    margin: 0;
  }

  .case-card__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
    color: #000000;
    margin: 0;
    line-height: 1.4;
  }

  .case-card__link:hover .case-card__title {
    color: #e02b10;
  }

  .case-card__category {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.2px;
    text-transform: uppercase;
    color: #888888;
    margin: 0;
  }

  .case-card__desc {
    display: none;
  }
</style>
