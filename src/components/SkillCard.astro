---
export interface Props {
  number: string;   // e.g. "001"
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
}

const { number, title, description, image, imageAlt = title } = Astro.props;
---

<article class="skill-card">
  <!-- Thumbnail -->
  <div class="skill-card__img-wrap" aria-hidden="true">
    <img
      src={image}
      alt=""
      class="skill-card__img"
      loading="lazy"
      decoding="async"
      width="400"
      height="280"
    />
  </div>

  <!-- Body -->
  <div class="skill-card__body">
    <span class="skill-card__number" aria-hidden="true">{number}</span>
    <h3 class="skill-card__title">{title}</h3>
    <p class="skill-card__desc">{description}</p>
  </div>
</article>

<style>
  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    background: transparent;
    border-radius: 0;
    transition: all 0.3s ease;
    height: 100%;
  }

  .skill-card:hover {
    background: transparent;
    transform: none;
    box-shadow: none;
  }

  /* Thumbnail */
  .skill-card__img-wrap {
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: 16 / 9;
    background-color: #1a1a1a;
    margin: 0 0 24px 0;
  }

  .skill-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    will-change: transform;
  }

  .skill-card:hover .skill-card__img {
    transform: scale(1.05);
  }

  /* Body */
  .skill-card__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
  }

  .skill-card__number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.6px;
    color: #e02b10;
    margin: 0;
    text-transform: uppercase;
  }

  .skill-card__title {
    font-family: 'Manrope', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #ffffff;
    margin: 0;
    line-height: 1.3;
  }

  .skill-card__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
  }
</style>
