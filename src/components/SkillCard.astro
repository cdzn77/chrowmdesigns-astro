---
export interface Props {
  number: string;   // e.g. "001"
  title: string;
  description: string;
  image: string;
  imageAlt?: string;
}

const { number, title, description, image, imageAlt = title } = Astro.props;
---

<article class="skill-card">
  <!-- Thumbnail -->
  <div class="skill-card__img-wrap" aria-hidden="true">
    <img
      src={image}
      alt=""
      class="skill-card__img"
      loading="lazy"
      decoding="async"
      width="400"
      height="280"
    />
  </div>

  <!-- Body -->
  <div class="skill-card__body">
    <span class="skill-card__number" aria-hidden="true">{number}</span>
    <h3 class="skill-card__title">{title}</h3>
    <p class="skill-card__desc">{description}</p>
  </div>
</article>

<style>
  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 4px;
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }

  .skill-card:hover {
    border-color: rgba(96, 211, 184, 0.25);
    background-color: rgba(96, 211, 184, 0.03);
  }

  /* Thumbnail */
  .skill-card__img-wrap {
    overflow: hidden;
    border-radius: 2px;
    aspect-ratio: 16 / 9;
    background-color: #2a2a2a;
  }

  .skill-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s ease;
    will-change: transform;
  }

  .skill-card:hover .skill-card__img {
    transform: scale(1.03);
    opacity: 0.9;
  }

  /* Body */
  .skill-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-card__number {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-accent);
  }

  .skill-card__title {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 1.5vw, 1.35rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin: 0;
  }

  .skill-card__desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-muted);
    margin: 0;
  }
</style>
