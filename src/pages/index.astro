---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroVideo from '../components/HeroVideo.astro';
import StatsMarquee from '../components/StatsMarquee.astro';
import CaseCard from '../components/CaseCard.astro';
import HireMarquee from '../components/HireMarquee.astro';
import SkillCard from '../components/SkillCard.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import cases from '../data/cases.json';

// Homepage shows the first 6 cases
const featuredCases = cases.slice(0, 6);

const skills = [
  {
    number: '001',
    title: 'Strategic Approach',
    description:
      'I align design with your brand, audience, and business goals to create strategic, user-focused digital experiences that deliver measurable results.',
    image: '/images/strategic_approach_thumb.webp',
  },
  {
    number: '002',
    title: 'User Experience',
    description:
      'Delivering excellent user experiences is essential for building trust and is central to my approach, which focuses on intuitive functionality, simplicity, and delight.',
    image: '/images/user_experience_thumb.webp',
  },
  {
    number: '003',
    title: 'Interactive Design',
    description:
      'Design is central to my work, where I combine creativity and expertise to achieve outstanding results.',
    image: '/images/interactive_design_thumb.webp',
  },
  {
    number: '004',
    title: 'Digital Experiences',
    description:
      'I design end-to-end product journeys that balance usability, emotional impact, and brand expression across web and digital platforms.',
    image: '/images/digital_experiences_thumb.webp',
  },
];
---

<BaseLayout
  title="ChrowmDesigns"
  description="Angelo Manzano Jr. — Senior Product Designer with 20 years of experience crafting digital experiences that connect, engage, and inspire."
>

  <!-- Organization structured data -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ChrowmDesigns",
    "alternateName": "CHRØWM Designs",
    "url": "https://chrowmdesigns.com",
    "logo": "https://chrowmdesigns.com/images/logo-1.webp",
    "description": "Independent design studio specializing in UX strategy, brand design, and digital product experiences.",
    "foundingDate": "1999",
    "founder": {
      "@type": "Person",
      "name": "Angelo Manzano Jr.",
      "jobTitle": "Senior UX Strategist & Creative Director",
      "url": "https://chrowmdesigns.com/about"
    },
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "FL",
      "addressCountry": "US"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "business",
      "email": "chile@chrowmdesigns.com"
    },
    "sameAs": [
      "https://www.linkedin.com/in/angelomanzano"
    ]
  })} />

  <!-- 1. Hero -->
  <HeroVideo />

  <!-- 2. Stats Marquee -->
  <StatsMarquee />

  <!-- 3. Featured Image -->
  <section class="featured-image" aria-label="Featured work">
    <div class="featured-image__img-wrap">
      <img
        src="/images/marriott_tablet_home.webp"
        alt="Marriott Vacation Club digital experience on tablet — enterprise UX redesign"
        class="featured-image__img"
        width="1620"
        height="850"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="featured-image__caption">
      <p class="featured-image__text">
        Crafting digital experiences that connect, engage and inspire.
      </p>
      <a href="/cases" class="featured-image__link">
        Browse all cases
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M2 7H12M12 7L7 2M12 7L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- 4. Case Study Grid -->
  <section class="cases-grid" aria-labelledby="cases-heading">
    <h2 class="visually-hidden" id="cases-heading">Featured Case Studies</h2>
    <div class="cases-grid__inner">
      {featuredCases.map((c, i) => (
        <CaseCard
          title={c.title}
          category={c.category}
          thumbnail={c.thumbnail}
          href={c.url}
          offset={i % 2 === 1}
          loading={i < 2 ? 'eager' : 'lazy'}
        />
      ))}
    </div>
    <div class="cases-grid__footer">
      <a href="/cases" class="cases-grid__all-link">
        View all case studies
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M2 7H12M12 7L7 2M12 7L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- 5. Hire Marquee -->
  <HireMarquee />

  <!-- 6. The Studio -->
  <section class="studio" aria-labelledby="studio-heading">
    <div class="studio__inner">
      <div class="studio__label">The studio</div>
      <h2 class="studio__heading" id="studio-heading">
        I'm an independent design studio blending creativity and strategy to
        craft standout digital products since 2000.
      </h2>
      <div class="studio__links">
        <a href="/about" class="studio__link">
          Learn More
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 7H12M12 7L7 2M12 7L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/cases" class="studio__link">
          Browse all cases
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 7H12M12 7L7 2M12 7L7 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 7. Portrait Section -->
  <section class="portrait" aria-label="About Angelo Manzano Jr.">
    <div class="portrait__img-wrap">
      <img
        src="/images/foot_top.webp"
        alt="Angelo Manzano Jr. — Senior Product Designer and UX Strategist"
        class="portrait__img"
        width="1620"
        height="850"
        loading="lazy"
        decoding="async"
      />
      <div class="portrait__overlay" aria-hidden="true">
        <span class="portrait__wordmark">ChrowmDesi&#x2014;</span>
      </div>
    </div>
  </section>

  <!-- 8. Skills Section -->
  <section class="skills" aria-labelledby="skills-heading">
    <div class="skills__header">
      <h2 class="skills__heading" id="skills-heading">
        Skills To Pay The Bills
      </h2>
    </div>
    <div class="skills__grid">
      {skills.map((skill) => (
        <SkillCard
          number={skill.number}
          title={skill.title}
          description={skill.description}
          image={skill.image}
        />
      ))}
    </div>
  </section>

  <!-- 9. CTA Banner -->
  <CTABanner />

  <!-- 10. Footer -->
  <Footer />

</BaseLayout>

<style>
  /* ── Featured Image ─────────────────────────────── */
  .featured-image {
    background-color: var(--color-primary);
  }

  .featured-image__img-wrap {
    width: 100%;
    overflow: hidden;
    max-height: 80vh;
  }

  .featured-image__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-image__caption {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 3rem clamp(1.5rem, 5vw, 5rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .featured-image__text {
    font-family: var(--font-sans);
    font-size: clamp(1.2rem, 2.5vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-white);
    margin: 0;
    max-width: 600px;
  }

  .featured-image__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: gap 0.2s ease;
  }

  .featured-image__link:hover {
    gap: 0.8rem;
  }

  /* ── Cases Grid ──────────────────────────────────── */
  .cases-grid {
    padding: var(--section-padding-y) clamp(1.5rem, 5vw, 5rem);
    background-color: var(--color-primary);
  }

  .cases-grid__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }

  .cases-grid__footer {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
  }

  .cases-grid__all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    text-decoration: none;
    padding: 0.8rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 100px;
    transition: border-color 0.2s ease, color 0.2s ease, gap 0.2s ease;
  }

  .cases-grid__all-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    gap: 0.8rem;
  }

  @media (max-width: 640px) {
    .cases-grid__inner {
      grid-template-columns: 1fr;
    }
    /* Reset offset on single column */
    :global(.case-card--offset) {
      margin-top: 0;
    }
  }

  /* ── Studio ──────────────────────────────────────── */
  .studio {
    padding: var(--section-padding-y) clamp(1.5rem, 5vw, 5rem);
    background-color: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .studio__inner {
    max-width: 800px;
  }

  .studio__label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .studio__heading {
    font-family: var(--font-sans);
    font-size: clamp(1.6rem, 3.5vw, 3rem);
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1.2;
    color: var(--color-white);
    margin: 0 0 2.5rem;
  }

  .studio__links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .studio__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-white);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .studio__link:hover {
    color: var(--color-accent);
    gap: 0.8rem;
  }

  /* ── Portrait ────────────────────────────────────── */
  .portrait {
    position: relative;
    background-color: var(--color-primary);
    overflow: hidden;
  }

  .portrait__img-wrap {
    position: relative;
    width: 100%;
  }

  .portrait__img {
    width: 100%;
    height: auto;
    max-height: 90vh;
    object-fit: cover;
    display: block;
  }

  .portrait__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: clamp(1.5rem, 5vw, 5rem);
    background: linear-gradient(
      to top,
      rgba(27, 27, 27, 0.7) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .portrait__wordmark {
    font-family: var(--font-sans);
    font-size: clamp(3rem, 10vw, 10rem);
    font-weight: 400;
    letter-spacing: -0.05em;
    color: rgba(255, 255, 255, 0.12);
    line-height: 1;
    user-select: none;
  }

  /* ── Skills ──────────────────────────────────────── */
  .skills {
    padding: var(--section-padding-y) clamp(1.5rem, 5vw, 5rem);
    background-color: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .skills__header {
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .skills__heading {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 400;
    letter-spacing: -0.04em;
    color: var(--color-white);
    margin: 0;
  }

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2vw, 2rem);
  }

  @media (max-width: 1024px) {
    .skills__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
