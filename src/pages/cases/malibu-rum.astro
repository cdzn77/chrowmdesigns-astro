---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyEditorial from '../../components/CaseStudyEditorial.astro';
import CasePrevNext from '../../components/CasePrevNext.astro';
import Footer from '../../components/Footer.astro';

const metadata = {
  title: 'Malibu Rum — Pernod Ricard | ChrowmDesigns',
  description: '200+ branded assets. 60M impressions. A unified creative system delivered across 101 consecutive days that set Malibu\'s brand consistency standard.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <CaseStudyEditorial
    client="Malibu Rum / Pernod Ricard USA"
    projectTitle="101 Days of Because Summer"
    projectSubtitle="Creative Systems & Campaign Design"
    year={2020}
    introRightText="200+ branded creative assets delivered across 101 consecutive days without a single brand consistency issue. Built a unified visual system centered on 'summer as sensation' that scaled across social, email, live activations, and Snapchat lenses, generating 60M impressions."
    role="Senior UX Strategist & Creative Lead"

    heroImage="/images/malibu-rum_hero.webp"
    heroImageAlt="Malibu Rum summer campaign — 101 Days of Because Summer"

    section3Title="Research & Brand Consistency Analysis"
    section3LeftText="I audited Malibu's existing social archive across two prior summer seasons, cataloguing the specific points where brand consistency broke down: which asset types showed the most drift, which color treatments diverged most from the core palette, and which content categories generated the highest engagement despite being produced inconsistently."
    section3RightText="High-performing content clustered around authenticity signals: real ingredients, real settings, low-production-value moments that felt unscripted. I reviewed the brand guidelines in detail, then stress-tested them against the asset types the campaign required. Several gaps became apparent: no rules for dark backgrounds, no motion treatment principles, and no defined hierarchy for co-branding moments."
    section3Image1="/images/malibu01.webp"
    section3Image1Alt="Malibu Rum — campaign overview"
    section3Image2="/images/malibu02.webp"
    section3Image2Alt="Malibu — brand audit findings"
    section3Image3="/images/malibu03.webp"
    section3Image3Alt="Malibu — visual language system"

    section4Image="/images/malibu04.webp"
    section4ImageAlt="Malibu — visual language examples"

    section5Title="Visual Language System: Summer as Sensation"
    section5LeftText="The design language centered on one idea: summer as a physical sensation. Aqua teals, sun-bleached oranges, and natural textures—woodgrain, lime peel, grill marks—were built into every asset category. Bold hand-painted headline fonts paired with rounded sans-serif body copy kept the tone friendly and unhurried."
    section5RightText="Texture and depth layering used composited photography and vector overlays to simulate handcrafted quality at production speed. The system needed flexibility to support recipe graphics, live activation overlays, and Snapchat lenses—all recognizable as part of one cohesive campaign despite their different technical requirements."
    section5Image1="/images/malibu04.webp"
    section5Image1Alt="Visual language elements"
    section5Image2="/images/malibu02.webp"
    section5Image2Alt="Brand palette and guidelines"
    section5Image3="/images/malibu03.webp"
    section5Image3Alt="Component system"

    section6Items={[
      { image: '/images/malibu05.webp', alt: 'Toolkit asset library' },
      { image: '/images/malibu06.webp', alt: 'Campaign execution examples' },
      { image: '/images/malibu04.webp', alt: 'Visual language standards' },
    ]}

    section7Image="/images/malibu01.webp"
    section7ImageAlt="Malibu Rum — campaign overview"
    section7Text="200+ Assets Built for Production Speed"

    section8Title="Toolkit Architecture & Campaign Execution"
    section8LeftText="I delivered over 200 branded elements: logos, stickers, icons, and typographic treatments, all built as layered PSDs and vector assets that animation teams could work from directly. Export templates covered 16:9, 1:1, and 9:16 aspect ratios. Integrated grid systems handled both static and carousel posts."
    section8RightText="Every asset in the toolkit was built so a designer unfamiliar with the campaign could pick it up and produce on-brand content within 30 minutes. Over 101 consecutive days I worked closely with the motion team on storyboard-to-final-cut consistency and coordinated with content strategists on the release schedule. The Bean Cam and #Shellfies activations were technically complex, requiring live-stream overlays and Snapchat lens integration while maintaining full brand consistency."
    section8Image1="/images/malibu05.webp"
    section8Image1Alt="Toolkit asset library"
    section8Image2="/images/malibu06.webp"
    section8Image2Alt="Campaign execution examples"
    section8Image3="/images/malibu04.webp"
    section8Image3Alt="Visual language system"

    section9Title="Results & Multi-Market Adoption"
    section9LeftText="25% increase in social engagement over the prior summer campaign baseline. 60M combined impressions across organic and paid placements over 101 days. 200+ branded elements produced without a single brand consistency escalation."
    section9RightText="The creative system was adopted by regional marketing teams in 4 international markets, proving its scalability and clarity. 101 consecutive days of on-brand content across three platforms with zero missed publishing dates demonstrated both the system's robustness and the team's ability to execute at scale."
    section9Image1="/images/malibu05.webp"
    section9Image1Alt="Asset library components"
    section9Image2="/images/malibu06.webp"
    section9Image2Alt="Campaign execution final examples"

    section10Image="/images/malibu01.webp"
    section10ImageAlt="Malibu Rum campaign full scope"
  />
  <CasePrevNext currentSlug="malibu-rum" />
  <Footer />
</BaseLayout>
