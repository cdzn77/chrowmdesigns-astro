---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyEditorial from '../../components/CaseStudyEditorial.astro';
import CasePrevNext from '../../components/CasePrevNext.astro';
import Footer from '../../components/Footer.astro';

const metadata = {
  title: 'Marriott Vacation Club | ChrowmDesigns',
  description: 'Resolved 47 friction points across enterprise systems. Transformed a transactional booking platform into an aspirational lifestyle ecosystem.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <CaseStudyEditorial
    client="Marriott International"
    projectTitle="Marriott Vacation Club"
    projectSubtitle="Enterprise UX & Digital Transformation"
    year={2021}
    introRightText="Resolved 47 friction points across enterprise systems for four brands: Marriott, Hyatt, Sheraton, and ILG. Transformed a transactional booking platform into an aspirational lifestyle ecosystem, reducing primary navigation from 12 categories to 3 user-intent-driven categories."
    role="Lead Experience Designer"

    heroImage="/images/marriott_hero.webp"
    heroImageAlt="Marriott Vacation Club digital platform on mobile"

    section3Title="Research & Navigation Strategy"
    section3LeftText="Heuristic audits, stakeholder workshops, and behavioral analytics revealed journey breakdowns. Usability testing involved three user groups: prospects, new members, and established owners. Members who understood their benefits booked more. The redesign had to make benefit comprehension the first job of the experience."
    section3RightText="Primary navigation was reduced from 12 to 3 categories: Explore Destinations, Manage Membership, Book Your Stay. Category names reflected user goals rather than business structure. C-suite stakeholder alignment positioned UX clarity as a revenue strategy, not a design preference."
    section3Image1="/images/marriott01.webp"
    section3Image1Alt="Marriott Vacation Club — mobile navigation audit"
    section3Image2="/images/marriott02.webp"
    section3Image2Alt="Marriott — user research sessions"
    section3Image3="/images/marriott03.webp"
    section3Image3Alt="Marriott — journey mapping workshop"

    section4Image="/images/marriott07.webp"
    section4ImageAlt="Marriott — design system components"

    section5Title="Mobile-First Design System Architecture"
    section5LeftText="Gesture-driven interface built for thumb-zone accessibility and one-handed use. Progressive disclosure through card-based UI revealed complexity gradually. Components covered iOS, Android, and web with WCAG 2.1 AA standards compliance."
    section5RightText="The system prioritized benefit comprehension through visual hierarchy and progressive information reveal. Users encountered value propositions before complexity, supporting the core business goal of reducing member confusion and refund requests."
    section5Image1="/images/marriott04.webp"
    section5Image1Alt="Marriott — wireframe navigation"
    section5Image2="/images/marriott05.webp"
    section5Image2Alt="Marriott — card-based UI"
    section5Image3="/images/marriott06.webp"
    section5Image3Alt="Marriott — mobile prototype"

    section6Items={[
      { image: '/images/marriott08.webp', alt: 'Brand unification across four properties' },
      { image: '/images/marriott09.webp', alt: 'Design system governance' },
      { image: '/images/marriott07.webp', alt: 'Design system components' },
    ]}

    section7Image="/images/marriott10.webp"
    section7ImageAlt="Marriott — final mobile screens"
    section7Text="Multi-Brand Unification Framework"

    section8Title="Cross-Brand Design System"
    section8LeftText="Engagement spanned four brands: Marriott Vacation Club, Hyatt, Sheraton, and ILG. A unified design language created experiential consistency while preserving brand distinctions. Each brand maintained its visual identity while sharing core interaction patterns and information architecture."
    section8RightText="Design system training and governance documentation ensured quality post-engagement. The framework established which elements were flexible for brand differentiation and which were fixed for functional consistency across all properties."
    section8Image1="/images/marriott08.webp"
    section8Image1Alt="Marriott — brand unification across four properties"
    section8Image2="/images/marriott10.webp"
    section8Image2Alt="Marriott — final mobile screens"
    section8Image3="/images/marriott11.webp"
    section8Image3Alt="Marriott — responsive web implementation"

    section9Title="Results & Enterprise-Scale Impact"
    section9LeftText="40% mobile conversion gap identified between mobile and desktop; redesign targeted parity. Navigation reduced from 12 categories to 3, organized by user intent rather than business structure. 47 friction points mapped across member journeys and addressed through IA restructure and progressive disclosure."
    section9RightText="Full WCAG 2.1 AA compliance achieved across iOS, Android, and responsive web. Design system was deployed across 4 brands with internal team training and comprehensive governance documentation, enabling sustainable quality maintenance post-engagement."
    section9Image1="/images/marriott04.webp"
    section9Image1Alt="Navigation wireframes"
    section9Image2="/images/marriott06.webp"
    section9Image2Alt="Mobile prototype"

    section10Image="/images/marriott09.webp"
    section10ImageAlt="Marriott design system governance"
  />
  <CasePrevNext currentSlug="marriott-vacation-club" />
  <Footer />
</BaseLayout>
