---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyEditorial from '../../components/CaseStudyEditorial.astro';
import CasePrevNext from '../../components/CasePrevNext.astro';
import Footer from '../../components/Footer.astro';

const metadata = {
  title: 'Grounded Climate Solutions Summit | ChrowmDesigns',
  description: 'Turned climate anxiety into a community. 300% increase in webinar registrations and 10x content engagement driven entirely by strategic visual storytelling.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <CaseStudyEditorial
    client="Grounded"
    projectTitle="Grounded Climate Solutions"
    projectSubtitle="UX Strategy & Behavioral Design"
    year={2021}
    introRightText="A climate solutions platform that turned anxiety into community action. Behavioral design shifted from crisis-led imagery to solution-oriented storytelling, driving 300% increase in webinar registrations and 10x content engagement through strategic visual language."
    role="Senior UX Strategist"

    heroImage="/images/grounded_hero.webp"
    heroImageAlt="Grounded climate summit — editorial visual design"

    section3Title="Research & Behavioral Design Framework"
    section3LeftText="Analysis of behavioral research revealed audiences exposed to solution-framing alongside problem acknowledgment demonstrate measurably higher intent to act. The team audited 10 environmental nonprofit sites and benchmarked against editorial platforms like TED."
    section3RightText="The consistent finding: design that emphasized community and achievable action consistently outperformed crisis-led visual approaches. This insight shaped the entire design strategy—moving away from disaster imagery toward solution-oriented storytelling that conveyed both urgency and agency."
    section3Image1="/images/grounded_01.webp"
    section3Image1Alt="Grounded — visual language exploration"
    section3Image2="/images/grounded_02.webp"
    section3Image2Alt="Grounded — competitor audit"
    section3Image3="/images/grounded_03.webp"
    section3Image3Alt="Grounded — behavioral research findings"

    section4Image="/images/grounded_04.webp"
    section4ImageAlt="Grounded — final visual system"

    section5Title="Visual Language for Emotional Regulation"
    section5LeftText="The visual system used icy neutrals, misty greens, and calm blues instead of high-contrast crisis colors. Typography balanced authority with warmth. Photography guidelines prioritized human connection and solution-oriented imagery over disaster documentation."
    section5RightText="This approach required resisting conventional environmental design patterns that rely on shock and urgency. Instead, the system communicated care, competence, and community—visual signals that audiences subconsciously register as trustworthy and actionable rather than paralyzing."
    section5Image1="/images/grounded_04.webp"
    section5Image1Alt="Color system and typography"
    section5Image2="/images/grounded_julia.webp"
    section5Image2Alt="Grounded — speaker profile component"
    section5Image3="/images/grounded_05.webp"
    section5Image3Alt="Grounded — content grid layout"

    section6Items={[
      { image: '/images/grounded_01.webp', alt: 'Visual language exploration' },
      { image: '/images/grounded_02.webp', alt: 'Competitive audit findings' },
      { image: '/images/grounded_04.webp', alt: 'Visual system standards' },
    ]}

    section7Image="/images/grounded_web_01.webp"
    section7ImageAlt="Grounded — full website on desktop"
    section7Text="Modular Content Architecture for Scalability"

    section8Title="CMS & Team Independence"
    section8LeftText="Modular story components were designed to require no developer support, enabling the small Grounded team to update content independently. Navigation was structured around action categories rather than issue categories—meeting users at their intent rather than the organization's taxonomy."
    section8RightText="WordPress CMS was designed for small teams to maintain independently. Component documentation was written for non-technical users, and the system was handed off with comprehensive editorial guidelines ensuring design consistency as new content was added."
    section8Image1="/images/grounded_julia.webp"
    section8Image1Alt="Speaker profile component"
    section8Image2="/images/grounded_05.webp"
    section8Image2Alt="Content grid layout"
    section8Image3="/images/grounded_04.webp"
    section8Image3Alt="Visual system documentation"

    section9Title="Results & Community Impact"
    section9LeftText="300% increase in webinar registrations in the first quarter post-launch. 10x increase in content engagement versus the previous site. Full team achieved self-sufficiency within two weeks with zero support requests, proving the documentation and component system were effective."
    section9RightText="The platform was recognized by three environmental organizations for its innovative approach to behavioral design in climate communication. Sub-3 second load times were maintained across all pages, ensuring the solution-focused experience wasn't undermined by technical friction."
    section9Image1="/images/grounded_web_01.webp"
    section9Image1Alt="Full website implementation"

    section10Image="/images/grounded_01.webp"
    section10ImageAlt="Grounded visual language system"
  />
  <CasePrevNext currentSlug="grounded" />
  <Footer />
</BaseLayout>
