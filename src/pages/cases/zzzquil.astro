---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyEditorial from '../../components/CaseStudyEditorial.astro';
import CasePrevNext from '../../components/CasePrevNext.astro';
import Footer from '../../components/Footer.astro';

const metadata = {
  title: 'ZzzQuil — Procter & Gamble | ChrowmDesigns',
  description: 'Redesigned P&G\'s sleep brand from packaging to pixels. Native app, e-commerce site, and dark mode system for better sleep UX.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <CaseStudyEditorial
    client="Procter & Gamble — ZzzQuil"
    projectTitle="ZzzQuil Sleep App"
    projectSubtitle="Product Strategy & Mobile UX"
    year={2021}
    introRightText="Dark mode design reimagined for sleep physiology rather than aesthetic preference. Rebuilt the color system from base saturation values up while maintaining brand recognition, proving context-appropriate design improves both usability and brand perception in wellness categories."
    role="Senior UX Strategist"

    heroImage="/images/zzzquil_hero.webp"
    heroImageAlt="ZzzQuil mobile app — dark mode sleep experience"

    section3Title="Research & Dark Mode Strategy"
    section3LeftText="Analysis covered color contrast ratios for pre-sleep screen usage, dark mode accessibility standards, and competitor app audits across 14 comparable sleep and wellness apps. The critical insight: packaging design and app design serve fundamentally different purposes in different contexts."
    section3RightText="User journey mapping identified critical handoff moments between platforms. What works on a grocery shelf—vibrant, attention-grabbing—creates optical strain in a dark bedroom at 11 PM. The design had to prioritize the actual usage context over brand consistency expectations."
    section3Image1="/images/zzzquil01.webp"
    section3Image1Alt="ZzzQuil — color system audit"
    section3Image2="/images/zzzquil02.webp"
    section3Image2Alt="ZzzQuil — competitor audit"
    section3Image3="/images/zzzquil03.webp"
    section3Image3Alt="ZzzQuil — journey mapping"

    section4Image="/images/zzzquil04.webp"
    section4ImageAlt="ZzzQuil — dark mode color system"

    section5Title="Dark Mode as Core Design Philosophy"
    section5LeftText="Rather than treating dark mode as a color swap, I rebuilt the ZzzQuil color system from the base saturation values up. The goal was a palette that maintained brand recognition while becoming genuinely comfortable for extended pre-sleep use—a fundamentally different design brief than most dark mode implementations."
    section5RightText="The palette needed to feel like ZzzQuil while supporting sleep physiology. Reduced blue light, lower saturation, maintained legibility, but no longer caused the visual fatigue of bright purples and high contrasts. This required education with brand stakeholders about why visual impact mattered less than user comfort."
    section5Image1="/images/zzzquil04.webp"
    section5Image1Alt="Dark mode color system"
    section5Image2="/images/zzzquil05.webp"
    section5Image2Alt="ZzzQuil — soundscape mixer interface"
    section5Image3="/images/zzzquil06.webp"
    section5Image3Alt="ZzzQuil — sleep stories UI"

    section6Items={[
      { image: '/images/zzzquil02.webp', alt: 'Competitor audit findings' },
      { image: '/images/zzzquil03.webp', alt: 'Journey mapping analysis' },
      { image: '/images/zzzquil04.webp', alt: 'Color system documentation' },
    ]}

    section7Image="/images/zzzquil_phones-01.webp"
    section7ImageAlt="ZzzQuil — multi-screen overview"
    section7Text="Content-First Architecture & Navigation"

    section8Title="Platform Architecture & Design System"
    section8LeftText="The app's navigation was designed to recede as users engaged with content. The soundscape mixer became the most-used feature post-launch—a direct result of surfacing it in the primary interaction layer rather than burying it in a sub-menu."
    section8RightText="I built a modular design system that maintained brand integrity across mobile and web while respecting the different technical constraints and user expectations of each platform. Single design system deployed across iOS, Android, and responsive web with WCAG 2.1 AA compliance across all breakpoints."
    section8Image1="/images/zzzquil05.webp"
    section8Image1Alt="Soundscape mixer interface"
    section8Image2="/images/zzzquil06.webp"
    section8Image2Alt="Sleep stories UI design"
    section8Image3="/images/zzzquil_phones-01.webp"
    section8Image3Alt="Multi-screen overview"

    section9Title="Results & Usage Patterns"
    section9LeftText="Soundscape mixer became the most-used feature within 30 days of launch. System-default dark mode usage exceeded projections by significant margin. The app demonstrated that content-first architecture—surfacing the most-valuable feature prominently—directly influenced user behavior."
    section9RightText="Platform consistency was maintained through single design system deployment across iOS, Android, and responsive web. Multi-coast team coordination with structured async protocols ensured quality delivery despite timezone separation. The project validated that context-appropriate dark mode improves both usability and brand perception in wellness categories."
    section9Image1="/images/zzzquil04.webp"
    section9Image1Alt="Color system final implementation"
    section9Image2="/images/zzzquil_phones-01.webp"
    section9Image2Alt="App overview screens"

    section10Image="/images/zzzquil01.webp"
    section10ImageAlt="ZzzQuil color system complete implementation"
  />
  <CasePrevNext currentSlug="zzzquil" />
  <Footer />
</BaseLayout>
