---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CaseStudyEditorial from '../../components/CaseStudyEditorial.astro';
import CasePrevNext from '../../components/CasePrevNext.astro';
import Footer from '../../components/Footer.astro';

const metadata = {
  title: 'Carrabba\'s Italian Grill | ChrowmDesigns',
  description: 'Reduced recipe access time by 40% and grew mobile engagement 28%. A content platform that taught cooking instead of selling reservations.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <CaseStudyEditorial
    client="Carrabba's Italian Grill (Bloomin' Brands)"
    projectTitle="Carrabba's Kitchen"
    projectSubtitle="Content Strategy & UX Architecture"
    year={2019}
    introRightText="A content-driven culinary platform that reduced recipe access time by 40% and grew mobile engagement 28%. Transformed the restaurant brand from transactional booking site into an educational cooking resource that taught technique rather than selling reservations."
    role="Senior UX Strategist"

    heroImage="/images/carrabbas_hero.webp"
    heroImageAlt="Carrabba's Italian Grill — culinary content platform"

    section3Title="Research & Information Architecture Discovery"
    section3LeftText="Usability testing with 12 home cooks across skill levels revealed that experienced cooks browse by technique and ingredient, while novices browse by desired outcome. Audits of eight food platforms and three restaurant blogs showed successful examples separated discovery browsing from recipe execution layouts."
    section3RightText="Content was organized around technique and ingredient categories rather than promotional themes. Navigation paths for Popular, Recent, and topical filters provided multiple entry points without forcing linear journeys. Action-oriented titles like 'How to Boil the Perfect Pot of Pasta' set explicit expectations and drove higher click-through than descriptive headlines."
    section3Image1="/images/carrabbas01.webp"
    section3Image1Alt="Carrabba's — culinary platform overview"
    section3Image2="/images/carrabbas02.webp"
    section3Image2Alt="Carrabba's — usability testing findings"
    section3Image3="/images/carrabbas03.webp"
    section3Image3Alt="Carrabba's — content audit"

    section4Image="/images/carrabbas04.webp"
    section4ImageAlt="Carrabba's — information architecture"

    section5Title="Mobile-First Reading Experience"
    section5LeftText="Article layouts used scroll-optimized vertical flow with ingredient lists and instructions in clear hierarchy. The reading experience was designed for a kitchen context: large touch targets, minimal chrome, and easy scroll-back for reference while cooking."
    section5RightText="The design balanced Carrabba's brand warmth with functional clarity. Rich food photography led the visual hierarchy, using 'Carrabba's Tableside' custom serif for brand moments paired with clean sans-serif for body text readable at small mobile sizes."
    section5Image1="/images/carrabbas05.webp"
    section5Image1Alt="Carrabba's — mobile recipe layout"
    section5Image2="/images/carrabbas06.webp"
    section5Image2Alt="Carrabba's — ingredient list design"
    section5Image3="/images/carrabbas07.webp"
    section5Image3Alt="Carrabba's — navigation design"

    section6Items={[
      { image: '/images/carrabbas01.webp', alt: 'Culinary platform overview' },
      { image: '/images/carrabbas02.webp', alt: 'Usability testing findings' },
      { image: '/images/carrabbas04.webp', alt: 'Information architecture' },
    ]}

    section7Image="/images/carrabbas08.webp"
    section7ImageAlt="Carrabba's — final design system"
    section7Text="Visual System & Design Consistency"

    section8Title="Content-Driven Design System"
    section8LeftText="The design system balanced brand warmth with functional clarity. Rich food photography led the visual hierarchy, creating an aspirational yet accessible experience. Typography choices honored Carrabba's brand identity while ensuring readability in the kitchen context."
    section8RightText="Editorial guidelines were written to align content creation with UX strategy—a critical addition preventing design quality degradation as real content was added. The system ensured consistency across recipe types, seasonal content, and promotional moments without constraining editorial creativity."
    section8Image1="/images/carrabbas05.webp"
    section8Image1Alt="Recipe layout optimization"
    section8Image2="/images/carrabbas06.webp"
    section8Image2Alt="Ingredient list design"
    section8Image3="/images/carrabbas08.webp"
    section8Image3Alt="Final design system"

    section9Title="Results & Impact Metrics"
    section9LeftText="40% faster time-to-recipe versus prior site, measured via task timing across 12 usability sessions. 28% increase in mobile session depth following launch. Post-launch survey showed 78% of first-time visitors cited the platform as 'inviting' and 'easy to use.'"
    section9RightText="Content team achieved independent article production within 3 weeks of handoff, proving the editorial guidelines and design system were self-sustaining. Navigation efficiency improved from 6+ click sequences to 3-step browsing paths for core content discovery."
    section9Image1="/images/carrabbas04.webp"
    section9Image1Alt="Information architecture documentation"

    section10Image="/images/carrabbas_hero.webp"
    section10ImageAlt="Carrabba's culinary platform final implementation"
  />
  <CasePrevNext currentSlug="carrabbas" />
  <Footer />
</BaseLayout>
